const texts = {
  ru: {
    categoriesTitle: "Категории",
    categories: ["Авто", "Недвижимость", "Работа", "Одежда", "Электроника", "Услуги"],
    telegram: "Перейти в Telegram"
  },
  kg: {
    categoriesTitle: "Категориялар",
    categories: ["Унаа", "Кыймылсыз мүлк", "Жумуш", "Кийим", "Электроника", "Кызматтар"],
    telegram: "Telegram'га өтүү"
  },
  uz: {
    categoriesTitle: "Kategoriyalar",
    categories: ["Avto", "Ko‘chmas mulk", "Ish", "Kiyim", "Elektronika", "Xizmatlar"],
    telegram: "Telegram'ga o‘tish"
  }
};

function setLang(lang) {
  document.getElementById("categories-title").textContent = texts[lang].categoriesTitle;

  const grid = document.getElementById("categories");
  grid.innerHTML = "";
  texts[lang].categories.forEach(cat => {
    const div = document.createElement("div");
    div.className = "card";
    div.textContent = cat;
    grid.appendChild(div);
  });

  document.getElementById("telegram-btn").textContent = texts[lang].telegram;
}

// по умолчанию русский
setLang('ru');
